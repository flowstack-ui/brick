{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",

    "forceConsistentCasingInFileNames": true,
    "strict": true,

    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules", "**/*.test.*", "**/*.spec.*"]
}
