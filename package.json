{
  "name": "@flowstack-ui/brick",
  "version": "0.1.0",
  "description": "Styled React components built on Flowstack Atom.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "flowstack-ui",
    "brick",
    "react",
    "components",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/templateflow-io/templateflow.git",
    "directory": "packages/brick-ui/package"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "pack:check": "npm_config_cache=/tmp/brick-ui-npm-cache npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@flowstack-ui/atom": "0.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
