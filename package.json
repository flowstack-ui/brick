{
  "name": "@flowstack-ui/brick",
  "version": "0.1.0",
  "description": "Opinionated styled React components built on @flowstack-ui/atom.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "flowstack-ui",
    "brick",
    "react",
    "components",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flowstack-ui/brick.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button.d.ts",
      "default": "./dist/button.js"
    },
    "./card": {
      "types": "./dist/card.d.ts",
      "default": "./dist/card.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "default": "./dist/dialog.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./reset.css": "./dist/reset.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && npm run build:js && npm run build:css",
    "build:js": "tsc -p tsconfig.build.json",
    "build:css": "node scripts/build-styles.mjs --mode production",
    "build:css:dev": "node scripts/build-styles.mjs --mode development",
    "build:playground": "npm run build && vite build --config playground/vite.config.ts",
    "dev": "npm run dev:playground",
    "dev:playground": "npm run build && vite --config playground/vite.config.ts",
    "preview:playground": "vite preview --config playground/vite.config.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.tools.json && tsc -p test/types/tsconfig.json && tsc -p playground/tsconfig.json",
    "test": "npm run test:node && npm run test:components && npm run test:css",
    "test:node": "npm run build && node --test test/package/*.test.mjs",
    "test:components": "vitest run --coverage",
    "test:css": "node scripts/prototype-css.mjs",
    "test:browser": "npm run build:playground && playwright test --project=chromium",
    "test:browser:release": "npm run build:playground && playwright test",
    "test:visual:update": "npm run build:playground && playwright test playground/tests/visual.spec.ts --project=chromium --update-snapshots",
    "size:css": "node scripts/report-css-size.mjs",
    "pack:check": "node scripts/verify-package.mjs --dry-run",
    "verify:consumers": "npm run build && node scripts/verify-consumers.mjs",
    "check": "npm run typecheck && npm test && npm run build:playground && npm run pack:check && npm run verify:consumers",
    "prepublishOnly": "npm run build"
  },
  "browserslist": [
    "defaults and supports es6-module",
    "not IE 11"
  ],
  "overrides": {
    "glob": "13.0.6"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@flowstack-ui/atom": "0.3.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "browserslist": "^4.28.6",
    "jsdom": "^26.1.0",
    "lightningcss": "^1.32.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  }
}
